  State<SplashScreen> createState() => _SplashState();
}

class _SplashState extends State<SplashScreen>
    with SingleTickerProviderStateMixin {
  late AnimationController _ac;
  late Animation<double> _fade, _scale, _slide;

  @override
  void initState() {
    super.initState();
    _ac = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1800),
    );
    _fade = Tween<double>(begin: 0, end: 1).animate(
      CurvedAnimation(
        parent: _ac,
        curve: const Interval(0, .6, curve: Curves.easeIn),
      ),
    );
    _scale = Tween<double>(begin: .5, end: 1).animate(
      CurvedAnimation(
        parent: _ac,
        curve: const Interval(0, .7, curve: Curves.elasticOut),
      ),
    );
    _slide = Tween<double>(begin: 40, end: 0).animate(
      CurvedAnimation(
        parent: _ac,
        curve: const Interval(.3, 1, curve: Curves.easeOut),
      ),
    );
    _ac.forward();
    Future.delayed(const Duration(seconds: 3), () {
      if (!mounted) return;
      Navigator.pushReplacement(
        context,
        PageRouteBuilder(
          pageBuilder: (_, __, ___) => MainShell(s: widget.s),
          transitionDuration: const Duration(milliseconds: 800),
          transitionsBuilder: (_, a, __, child) =>
              FadeTransition(opacity: a, child: child),
        ),
      );
    });
  }

  @override
  void dispose() {
    _ac.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: Container(
        decoration: const BoxDecoration(gradient: C.gradient),
        child: Center(
          child: AnimatedBuilder(
            animation: _ac,
            builder: (_, __) => FadeTransition(
              opacity: _fade,
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  ScaleTransition(
                    scale: _scale,
                    child: Container(
                      width: 130,
                      height: 130,
                      decoration: BoxDecoration(
                        shape: BoxShape.circle,
                        gradient: const LinearGradient(
                          colors: [C.pLight, C.accent],
                          begin: Alignment.topLeft,
                          end: Alignment.bottomRight,
                        ),
                        boxShadow: [
                          BoxShadow(
                            color: C.pLight.withOpacity(.5),
                            blurRadius: 50,
                            spreadRadius: 15,
                          ),
                        ],
                      ),
                      child: const Icon(
                        Icons.directions_car_filled,
                        size: 70,
                        color: Colors.white,
                      ),
                    ),
                  ),
                  const SizedBox(height: 32),
                  Transform.translate(
                    offset: Offset(0, _slide.value),
                    child: Column(
                      children: [
                        const Text(
                          'SÜRVOX',
                          style: TextStyle(
                            fontSize: 46,
                            fontWeight: FontWeight.w900,
                            color: Colors.white,
                            letterSpacing: 6,
                          ),
                        ),
                        const Text(
                          'EHLİYET SINAV SORULARI',
                          style: TextStyle(
                            fontSize: 13,
                            color: C.aLight,
                            letterSpacing: 3,
                            fontWeight: FontWeight.w600,
