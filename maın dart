  static List<Q> byCat(Cat c) => all.where((q) => q.cat == c).toList();
  static List<Q> random(int n) {
    final list = List<Q>.from(all)..shuffle(Random());
    return list.take(n.clamp(0, list.length)).toList();
  }

  static List<Q> exam() {
    // Real exam: 50 questions distributed across categories
    final result = <Q>[];
    final targets = {
      Cat.trafik: 14,
      Cat.ilkYardim: 8,
      Cat.motor: 8,
      Cat.trafikAdabi: 6,
      Cat.levhalar: 6,
      Cat.aracTeknik: 5,
      Cat.ceza: 3,
      Cat.cevresel: 3,
    };
    for (final cat in Cat.values) {
      final qs = byCat(cat)..shuffle(Random());
      result.addAll(qs.take(targets[cat] ?? 2));
    }
    result.shuffle(Random());
    return result;
  }
