// ══════════════════════════════════════════════════════════════════
//  QUESTION MODEL
// ══════════════════════════════════════════════════════════════════
class Q {
  final String id, text, explanation;
  final List<String> opts;
  final int correct;
  final Cat cat;
  bool fav = false;

  Q({
    required this.id,
    required this.text,
    required this.opts,
    required this.correct,
    required this.cat,
    required this.explanation,
  });
}

