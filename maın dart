//  TEST SCREEN (soru çözme)
// ══════════════════════════════════════════════════════════════════
class TestScreen extends StatefulWidget {
  final List<Q> qs;
  final AppState s;
  final String title;
  const TestScreen({
    super.key,
    required this.qs,
    required this.s,
    required this.title,
  });
  @override
  State<TestScreen> createState() => _TestScreenState();
}

class _TestScreenState extends State<TestScreen>
    with SingleTickerProviderStateMixin {
  int _idx = 0;
  int? _sel;
  bool _answered = false;
  final Map<int, int> _answers = {};
  final Map<int, bool> _correct = {};
  late AnimationController _ac;
  late Animation<double> _shake;

  Q get cur => widget.qs[_idx];

  @override
  void initState() {
    super.initState();
    _ac = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 400),
    );
    _shake = Tween<double>(
      begin: 0,
      end: 1,
    ).animate(CurvedAnimation(parent: _ac, curve: Curves.elasticOut));
  }

  @override
  void dispose() {
    _ac.dispose();
    super.dispose();
  }

  void _select(int i) {
    if (_answered) return;
    final ok = i == cur.correct;
    setState(() {
      _sel = i;
      _answered = true;
      _answers[_idx] = i;
      _correct[_idx] = ok;
    });
    widget.s.answer(ok, cur.cat);
    if (!ok) _ac.forward(from: 0);
  }

  void _next() {
    if (_idx < widget.qs.length - 1) {
      setState(() {
        _idx++;
        _sel = _answers[_idx];
        _answered = _answers.containsKey(_idx);
      });
    } else {
      _showResult();
    }
  }

  void _showResult() {
    final ok = _correct.values.where((v) => v).length;
    final wr = _correct.values.where((v) => !v).length;
    final em = widget.qs.length - _answers.length;
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: C.card,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(28)),
      ),
      builder: (_) => _ResultSheet(
        ok: ok,
        wr: wr,
        em: em,
        total: widget.qs.length,
        onClose: () {
          Navigator.pop(context);
          Navigator.pop(context);
        },
      ),
    );
  }

  Color _optBg(int i) {
    if (!_answered) return C.cardHi;
    if (i == cur.correct) return C.ok.withOpacity(.25);
    if (i == _sel && i != cur.correct) return C.err.withOpacity(.25);
    return C.cardHi;
  }

  Color _optBorder(int i) {
    if (!_answered) return Colors.transparent;
    if (i == cur.correct) return C.okLight;
    if (i == _sel && i != cur.correct) return C.errLight;
    return Colors.transparent;
  }

  @override
  Widget build(BuildContext context) {
    final prog = (_idx + 1) / widget.qs.length;
    return Scaffold(
      appBar: AppBar(
        title: Text(widget.title),
        actions: [
          IconButton(
            icon: Icon(
              cur.fav ? Icons.bookmark : Icons.bookmark_border,
              color: C.aLight,
            ),
            onPressed: () {
              setState(() => cur.fav = !cur.fav);
              widget.s.toggleFav(cur.id);
            },
          ),
        ],
      ),
      body: Column(
        children: [
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 4),
            child: Column(
              children: [
                Row(
                  mainAxisAlignment: MainAxisAlignment.spaceBetween,
                  children: [
                    Text(
                      '${_idx + 1} / ${widget.qs.length}',
                      style: const TextStyle(color: C.txt2),
                    ),
                    Container(
                      padding: const EdgeInsets.symmetric(
                        horizontal: 10,
                        vertical: 3,
                      ),
                      decoration: BoxDecoration(
                        color: cur.cat.color.withOpacity(.2),
                        borderRadius: BorderRadius.circular(10),
                      ),
                      child: Text(
                        cur.cat.label,
                        style: TextStyle(
                          color: cur.cat.color,
                          fontSize: 12,
                          fontWeight: FontWeight.w700,
                        ),
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                ClipRRect(
                  borderRadius: BorderRadius.circular(4),
                  child: LinearProgressIndicator(
                    value: prog,
                    minHeight: 6,
                    backgroundColor: C.cardHi,
                    valueColor: const AlwaysStoppedAnimation(C.pLight),
                  ),
                ),
              ],
            ),
          ),
          Expanded(
            child: AnimatedBuilder(
              animation: _shake,
              builder: (_, child) => Transform.translate(
                offset: _answered && _sel != cur.correct
                    ? Offset(
                        sin(_shake.value * pi * 6) * 8 * (1 - _shake.value),
                        0,
                      )
                    : Offset.zero,
                child: child,
              ),
              child: SingleChildScrollView(
                padding: const EdgeInsets.all(16),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const SizedBox(height: 8),
                    Container(
                      width: double.infinity,
                      padding: const EdgeInsets.all(22),
                      decoration: BoxDecoration(
                        color: C.card,
                        borderRadius: BorderRadius.circular(22),
                        border: Border.all(color: C.cardHi),
                      ),
                      child: Text(
                        cur.text,
                        style: const TextStyle(
                          color: C.txt,
                          fontSize: 17,
                          fontWeight: FontWeight.w600,
                          height: 1.55,
                        ),
                      ),
                    ),
                    const SizedBox(height: 18),
                    ...List.generate(cur.opts.length, (i) {
                      final letter = String.fromCharCode(65 + i);
                      return Padding(
                        padding: const EdgeInsets.only(bottom: 12),
                        child: GestureDetector(
                          onTap: () => _select(i),
                          child: AnimatedContainer(
                            duration: const Duration(milliseconds: 250),
                            padding: const EdgeInsets.all(16),
                            decoration: BoxDecoration(
                              color: _optBg(i),
                              borderRadius: BorderRadius.circular(16),
                              border: Border.all(
                                color: _optBorder(i),
                                width: 2,
                              ),
                            ),
                            child: Row(
                              children: [
                                Container(
                                  width: 34,
                                  height: 34,
                                  decoration: BoxDecoration(
                                    shape: BoxShape.circle,
                                    color: C.surface,
                                  ),
                                  child: Center(
                                    child: Text(
                                      letter,
                                      style: const TextStyle(
                                        color: C.pLight,
