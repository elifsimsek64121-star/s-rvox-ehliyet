class SignsScreen extends StatefulWidget {
  final AppState s;
  const SignsScreen({super.key, required this.s});
  @override
  State<SignsScreen> createState() => _SignsState();
}

class _SignsState extends State<SignsScreen>
    with SingleTickerProviderStateMixin {
  late TabController _tab;
  String _filter = 'Tümü';
  String _search = '';
  int _qi = 0;
  int? _qa;
  bool _qanswered = false;
  int _qcorrect = 0;

  @override
  void initState() {
    super.initState();
    _tab = TabController(length: 3, vsync: this);
  }

  @override
  void dispose() {
    _tab.dispose();
    super.dispose();
  }

  List<Sign> get _filtered {
    var list = signs;
    if (_filter != 'Tümü') list = list.where((s) => s.type == _filter).toList();
    if (_search.isNotEmpty)
      list = list
          .where(
            (s) =>
                s.name.toLowerCase().contains(_search.toLowerCase()) ||
                s.desc.toLowerCase().contains(_search.toLowerCase()),
          )
          .toList();
    return list;
  }

  List<String> _quizOpts(int idx) {
    final correct = signs[idx].name;
    final others = List<int>.generate(signs.length, (i) => i)..remove(idx);
    others.shuffle();
    final opts = [correct, ...others.take(3).map((i) => signs[i].name)]
      ..shuffle();
    return opts;
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Trafik Levhaları'),
        bottom: TabBar(
          controller: _tab,
          tabs: const [
            Tab(text: 'Tüm Levhalar'),
            Tab(text: 'Kategoriler'),
            Tab(text: 'Levha Quiz'),
          ],
          labelColor: C.pLight,
          unselectedLabelColor: C.txt2,
          indicatorColor: C.pLight,
        ),
      ),
      body: TabBarView(
        controller: _tab,
        children: [_allSigns(), _catSigns(), _quiz()],
      ),
    );
  }

  Widget _allSigns() {
    return Column(
      children: [
        Padding(
          padding: const EdgeInsets.all(12),
          child: TextField(
            onChanged: (v) => setState(() => _search = v),
            style: const TextStyle(color: C.txt),
            decoration: InputDecoration(
              hintText: 'Levha ara...',
              hintStyle: const TextStyle(color: C.txt2),
              prefixIcon: const Icon(Icons.search, color: C.txt2),
              filled: true,
              fillColor: C.card,
              border: OutlineInputBorder(
                borderRadius: BorderRadius.circular(14),
                borderSide: BorderSide.none,
              ),
            ),
          ),
        ),
        Expanded(
          child: GridView.builder(
            padding: const EdgeInsets.all(12),
            gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
              crossAxisCount: 2,
              childAspectRatio: .88,
              crossAxisSpacing: 12,
              mainAxisSpacing: 12,
            ),
            itemCount: _filtered.length,
            itemBuilder: (_, i) {
              final sg = _filtered[i];
              final borderColor = sg.color == 'red'
                  ? C.errLight
                  : sg.color == 'yellow'
                  ? C.warn
                  : sg.color == 'blue'
                  ? C.pLight
                  : sg.color == 'orange'
                  ? C.accent
                  : C.okLight;
              return GestureDetector(
                onTap: () => _showDetail(context, sg),
                child: AnimatedContainer(
                  duration: const Duration(milliseconds: 200),
                  decoration: BoxDecoration(
                    color: C.card,
                    borderRadius: BorderRadius.circular(20),
                    border: Border.all(color: borderColor.withOpacity(.4)),
                    boxShadow: [
                      BoxShadow(
                        color: borderColor.withOpacity(.1),
                        blurRadius: 12,
                      ),
                    ],
                  ),
                  padding: const EdgeInsets.all(14),
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Text(sg.emoji, style: const TextStyle(fontSize: 44)),
                      const SizedBox(height: 8),
                      Text(
                        sg.name,
                        textAlign: TextAlign.center,
                        style: const TextStyle(
                          color: C.txt,
                          fontWeight: FontWeight.w700,
                          fontSize: 13,
                        ),
                        maxLines: 2,
                        overflow: TextOverflow.ellipsis,
                      ),
                      const SizedBox(height: 4),
                      Container(
                        padding: const EdgeInsets.symmetric(
                          horizontal: 8,
                          vertical: 2,
                        ),
                        decoration: BoxDecoration(
                          color: borderColor.withOpacity(.15),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: Text(
                          sg.type,
                          style: TextStyle(
                            color: borderColor,
                            fontSize: 10,
                            fontWeight: FontWeight.w700,
                          ),
                        ),
                      ),
                    ],
                  ),
                ),
              );
            },
          ),
        ),
      ],
    );
  }

  Widget _catSigns() {
    const types = [
      'Tümü',
      'Yasak',
      'Düzenleyici',
      'Uyarı',
      'Zorunluluk',
      'Bilgi',
    ];
    return Column(
      children: [
        SingleChildScrollView(
          scrollDirection: Axis.horizontal,
          padding: const EdgeInsets.all(12),
          child: Row(
            children: types
                .map(
                  (t) => Padding(
                    padding: const EdgeInsets.only(right: 8),
                    child: GestureDetector(
                      onTap: () => setState(() => _filter = t),
                      child: AnimatedContainer(
                        duration: const Duration(milliseconds: 200),
                        padding: const EdgeInsets.symmetric(
                          horizontal: 16,
                          vertical: 8,
                        ),
                        decoration: BoxDecoration(
                          color: _filter == t ? C.primary : C.card,
                          borderRadius: BorderRadius.circular(20),
                          border: Border.all(
                            color: _filter == t ? C.pLight : C.cardHi,
                          ),
                        ),
                        child: Text(
                          t,
                          style: TextStyle(
                            color: _filter == t ? Colors.white : C.txt2,
                            fontWeight: FontWeight.w700,
                            fontSize: 13,
                          ),
                        ),
                      ),
                    ),
                  ),
                )
                .toList(),
          ),
        ),
        Expanded(
          child: ListView.builder(
            padding: const EdgeInsets.symmetric(horizontal: 12),
            itemCount: _filtered.length,
            itemBuilder: (_, i) {
              final sg = _filtered[i];
              return GestureDetector(
                onTap: () => _showDetail(context, sg),
                child: Container(
                  margin: const EdgeInsets.only(bottom: 10),
                  padding: const EdgeInsets.all(16),
                  decoration: BoxDecoration(
                    color: C.card,
                    borderRadius: BorderRadius.circular(18),
                  ),
                  child: Row(
                    children: [
                      Text(sg.emoji, style: const TextStyle(fontSize: 40)),
                      const SizedBox(width: 16),
                      Expanded(
                        child: Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          children: [
                            Text(
                              sg.name,
                              style: const TextStyle(
                                color: C.txt,
                                fontWeight: FontWeight.w700,
                                fontSize: 15,
                              ),
                            ),
                            const SizedBox(height: 4),
                            Text(
                              sg.desc,
                              style: const TextStyle(
                                color: C.txt2,
                                fontSize: 12,
                                height: 1.4,
                              ),
                              maxLines: 2,
                              overflow: TextOverflow.ellipsis,
                            ),
                          ],
                        ),
                      ),
                      const Icon(Icons.info_outline, color: C.txt2, size: 18),
                    ],
                  ),
                ),
              );
            },
          ),
        ),
      ],
    );
  }

  Widget _quiz() {
    if (_qi >= signs.length) {
      return Center(
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('🏆', style: TextStyle(fontSize: 72)),
            const SizedBox(height: 16),
            const Text(
              'Quiz Tamamlandı!',
              style: TextStyle(
                color: C.txt,
                fontWeight: FontWeight.w900,
                fontSize: 24,
              ),
            ),
            const SizedBox(height: 8),
            Text(
              '$_qcorrect/${signs.length} doğru cevap',
              style: const TextStyle(color: C.pLight, fontSize: 16),
            ),
            const SizedBox(height: 8),
            Text(
              '${(_qcorrect / signs.length * 100).toStringAsFixed(0)}% Başarı',
              style: const TextStyle(
                color: C.aLight,
                fontSize: 20,
                fontWeight: FontWeight.w900,
              ),
            ),
            const SizedBox(height: 28),
            ElevatedButton.icon(
              onPressed: () => setState(() {
                _qi = 0;
                _qa = null;
                _qanswered = false;
                _qcorrect = 0;
              }),
              icon: const Icon(Icons.refresh),
              label: const Text(
                'Tekrar Başla',
                style: TextStyle(fontWeight: FontWeight.w800),
              ),
              style: ElevatedButton.styleFrom(
                backgroundColor: C.primary,
                foregroundColor: Colors.white,
                padding: const EdgeInsets.symmetric(
                  horizontal: 32,
                  vertical: 14,
                ),
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(16),
                ),
              ),
            ),
          ],
        ),
      );
    }
    final sg = signs[_qi];
    final opts = _quizOpts(_qi);
    return Padding(
      padding: const EdgeInsets.all(20),
      child: Column(
        children: [
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text(
                '${_qi + 1}/${signs.length}',
                style: const TextStyle(color: C.txt2),
              ),
              Text(
                '$_qcorrect doğru',
                style: const TextStyle(
                  color: C.okLight,
                  fontWeight: FontWeight.w700,
                ),
              ),
            ],
          ),
          const SizedBox(height: 8),
          ClipRRect(
            borderRadius: BorderRadius.circular(4),
            child: LinearProgressIndicator(
              value: _qi / signs.length,
              minHeight: 5,
              backgroundColor: C.cardHi,
              valueColor: const AlwaysStoppedAnimation(C.pLight),
            ),
          ),
          const SizedBox(height: 28),
          const Text(
            'Bu levhanın adı nedir?',
            style: TextStyle(color: C.txt2, fontSize: 16),
          ),
          const SizedBox(height: 16),
          Container(
            width: 130,
            height: 130,
            decoration: BoxDecoration(
              color: C.card,
              borderRadius: BorderRadius.circular(26),
              boxShadow: [
                BoxShadow(color: C.pLight.withOpacity(.15), blurRadius: 20),
              ],
            ),
            child: Center(
              child: Text(sg.emoji, style: const TextStyle(fontSize: 76)),
            ),
          ),
          const SizedBox(height: 28),
          ...opts.map((opt) {
            final isCorrect = opt == sg.name;
            Color bg = C.cardHi;
            Color border = Colors.transparent;
            if (_qanswered) {
              if (isCorrect) {
                bg = C.ok.withOpacity(.2);
                border = C.okLight;
              } else if (_qa != null && opts[_qa!] == opt && !isCorrect) {
                bg = C.err.withOpacity(.2);
                border = C.errLight;
              }
            }
            return Padding(
              padding: const EdgeInsets.only(bottom: 10),
              child: GestureDetector(
                onTap: () {
                  if (_qanswered) return;
                  final idx = opts.indexOf(opt);
                  setState(() {
                    _qa = idx;
                    _qanswered = true;
                    if (opt == sg.name) _qcorrect++;
                  });
                },
                child: AnimatedContainer(
                  duration: const Duration(milliseconds: 250),
                  padding: const EdgeInsets.symmetric(
                    vertical: 15,
                    horizontal: 20,
                  ),
                  decoration: BoxDecoration(
                    color: bg,
                    borderRadius: BorderRadius.circular(16),
                    border: Border.all(color: border, width: 2),
                  ),
                  child: Row(
                    children: [
                      Expanded(
                        child: Text(
                          opt,
                          textAlign: TextAlign.center,
                          style: const TextStyle(
                            color: C.txt,
                            fontWeight: FontWeight.w700,
                            fontSize: 15,
                          ),
                        ),
                      ),
                      if (_qanswered && isCorrect)
                        const Icon(Icons.check_circle, color: C.okLight),
                      if (_qanswered &&
                          _qa != null &&
                          opts[_qa!] == opt &&
                          !isCorrect)
                        const Icon(Icons.cancel, color: C.errLight),
                    ],
                  ),
                ),
              ),
            );
          }),
          if (_qanswered) ...[
            const SizedBox(height: 16),
            SizedBox(
              width: double.infinity,
              child: ElevatedButton(
                onPressed: () => setState(() {
                  _qi++;
                  _qa = null;
                  _qanswered = false;
                }),
                style: ElevatedButton.styleFrom(
                  backgroundColor: C.primary,
                  foregroundColor: Colors.white,
                  padding: const EdgeInsets.symmetric(vertical: 14),
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(16),
                  ),
                ),
                child: Text(
                  _qi < signs.length - 1 ? 'Sonraki Levha →' : 'Sonucu Gör',
                  style: const TextStyle(fontWeight: FontWeight.w800),
                ),
              ),
            ),
          ],
        ],
      ),
    );
  }

  void _showDetail(BuildContext ctx, Sign sg) {
    final borderColor = sg.color == 'red'
        ? C.errLight
        : sg.color == 'yellow'
        ? C.warn
        : sg.color == 'blue'
        ? C.pLight
        : sg.color == 'orange'
        ? C.accent
        : C.okLight;
    showModalBottomSheet(
      context: ctx,
      backgroundColor: C.card,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(28)),
      ),
      builder: (_) => Padding(
        padding: const EdgeInsets.all(32),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Container(
              width: 44,
              height: 4,
              decoration: BoxDecoration(
                color: Colors.white24,
                borderRadius: BorderRadius.circular(2),
              ),
            ),
            const SizedBox(height: 24),
            Container(
              width: 100,
              height: 100,
              decoration: BoxDecoration(
                shape: BoxShape.circle,
                color: borderColor.withOpacity(.1),
                border: Border.all(color: borderColor, width: 3),
              ),
              child: Center(
                child: Text(sg.emoji, style: const TextStyle(fontSize: 54)),
              ),
            ),
            const SizedBox(height: 16),
            Text(
              sg.name,
              style: const TextStyle(
                color: C.txt,
                fontWeight: FontWeight.w900,
                fontSize: 22,
              ),
            ),
            const SizedBox(height: 6),
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 5),
              decoration: BoxDecoration(
                color: borderColor.withOpacity(.15),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Text(
                sg.type,
                style: TextStyle(
                  color: borderColor,
                  fontWeight: FontWeight.w700,
                ),
              ),
            ),
            const SizedBox(height: 16),
            Text(
              sg.desc,
              style: const TextStyle(color: C.txt2, fontSize: 15, height: 1.6),
              textAlign: TextAlign.center,
            ),
            const SizedBox(height: 28),
          ],
        ),
      ),
    );
  }
}

