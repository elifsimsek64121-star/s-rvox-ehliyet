class AppState extends ChangeNotifier {
  int navIdx = 0;
  int totalSolved = 0;
  int totalCorrect = 0;
  int streak = 7;
  int xp = 1250;
  int level = 5;
  bool isPremium = false;
  Set<String> favIds = {};
  Map<Cat, int> catScores = {};
  List<ExamResult> history = [];

  double get rate => totalSolved == 0 ? 0 : totalCorrect / totalSolved;

  void setNav(int i) {
    navIdx = i;
    notifyListeners();
  }

  void answer(bool ok, Cat cat) {
    totalSolved++;
    if (ok) {
      totalCorrect++;
      xp += 10;
      catScores[cat] = (catScores[cat] ?? 0) + 1;
    }
    level = (xp / 500).floor() + 1;
    notifyListeners();
  }

  void toggleFav(String id) {
    favIds.contains(id) ? favIds.remove(id) : favIds.add(id);
    notifyListeners();
  }

  void addResult(ExamResult r) {
    history.insert(0, r);
    notifyListeners();
  }

  void unlockPremium() {
    isPremium = true;
    notifyListeners();
  }
}

class ExamResult {
  final int correct, wrong, empty, total;
  final double score;
  final bool passed;
  final DateTime date;
  final Duration dur;
  ExamResult({
    required this.correct,
    required this.wrong,
    required this.empty,
    required this.total,
    required this.score,
    required this.passed,
    required this.dur,
  }) : date = DateTime.now();
}

