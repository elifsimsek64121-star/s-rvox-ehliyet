class _ExamResultState extends State<ExamResultScreen>
    with SingleTickerProviderStateMixin {
  late AnimationController _ac;
  late Animation<double> _sc, _fade;

  @override
  void initState() {
    super.initState();
    _ac = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 1000),
    );
    _sc = Tween<double>(
      begin: .3,
      end: 1,
    ).animate(CurvedAnimation(parent: _ac, curve: Curves.elasticOut));
    _fade = Tween<double>(
      begin: 0,
      end: 1,
    ).animate(CurvedAnimation(parent: _ac, curve: const Interval(.3, 1)));
    _ac.forward();
  }

  @override
  void dispose() {
    _ac.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final r = widget.res;
    return Scaffold(
      body: Container(
        decoration: BoxDecoration(
          gradient: LinearGradient(
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
            colors: r.passed
                ? [const Color(0xFF1B5E20), C.bg]
                : [const Color(0xFF7F0000), C.bg],
          ),
        ),
        child: SafeArea(
          child: SingleChildScrollView(
            padding: const EdgeInsets.all(28),
            child: Column(
              children: [
                const SizedBox(height: 24),
                AnimatedBuilder(
                  animation: _ac,
                  builder: (_, __) => ScaleTransition(
                    scale: _sc,
                    child: Text(
                      r.passed ? '🏆' : '😔',
                      style: const TextStyle(fontSize: 90),
                    ),
                  ),
                ),
                const SizedBox(height: 16),
                FadeTransition(
                  opacity: _fade,
                  child: Column(
                    children: [
                      Text(
                        r.passed ? 'SINAVI GEÇTİNİZ!' : 'TEKRAR DENEYİN',
                        style: TextStyle(
                          fontSize: 28,
                          fontWeight: FontWeight.w900,
                          color: r.passed ? C.okLight : C.errLight,
                        ),
                      ),
                      const SizedBox(height: 8),
                      Text(
