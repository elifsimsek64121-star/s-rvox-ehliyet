// ─────────────────────────── DATA MODELS ───────────────────────────
enum QuestionCategory {
  trafik,
  ilkYardim,
  motor,
  trafikAdabi,
  levhalar,
  aracTeknik,
  ceza,
}

extension QuestionCategoryExt on QuestionCategory {
  String get label {
    switch (this) {
      case QuestionCategory.trafik:
        return 'Trafik ve Çevre';
      case QuestionCategory.ilkYardim:
        return 'İlk Yardım';
      case QuestionCategory.motor:
        return 'Motor Bilgisi';
      case QuestionCategory.trafikAdabi:
        return 'Trafik Adabı';
      case QuestionCategory.levhalar:
        return 'Trafik Levhaları';
      case QuestionCategory.aracTeknik:
        return 'Araç Tekniği';
      case QuestionCategory.ceza:
        return 'Ceza Soruları';
    }
  }

  IconData get icon {
    switch (this) {
      case QuestionCategory.trafik:
        return Icons.traffic;
      case QuestionCategory.ilkYardim:
        return Icons.medical_services;
      case QuestionCategory.motor:
        return Icons.settings;
      case QuestionCategory.trafikAdabi:
        return Icons.people;
      case QuestionCategory.levhalar:
        return Icons.sign_language;
      case QuestionCategory.aracTeknik:
        return Icons.car_repair;
      case QuestionCategory.ceza:
        return Icons.gavel;
    }
  }

  Color get color {
    switch (this) {
      case QuestionCategory.trafik:
        return const Color(0xFF1976D2);
      case QuestionCategory.ilkYardim:
        return const Color(0xFFD32F2F);
      case QuestionCategory.motor:
        return const Color(0xFF388E3C);
      case QuestionCategory.trafikAdabi:
        return const Color(0xFF7B1FA2);
      case QuestionCategory.levhalar:
        return const Color(0xFFF57C00);
      case QuestionCategory.aracTeknik:
        return const Color(0xFF0097A7);
      case QuestionCategory.ceza:
        return const Color(0xFF5D4037);
    }
  }
}

class Question {
  final String id;
  final String text;
  final List<String> options;
  final int correctIndex;
  final QuestionCategory category;
  final String explanation;
  bool isFavorite;
  bool isMarked;

  Question({
    required this.id,
    required this.text,
    required this.options,
    required this.correctIndex,
    required this.category,
    required this.explanation,
    this.isFavorite = false,
    this.isMarked = false,
  });
}

class TrafficSign {
  final String name;
  final String description;
  final String emoji;
  final String type;
  const TrafficSign({
    required this.name,
    required this.description,
    required this.emoji,
    required this.type,
  });
}

