class SignsScreen extends StatefulWidget {
  const SignsScreen({super.key});
  @override
  State<SignsScreen> createState() => _SignsScreenState();
}

class _SignsScreenState extends State<SignsScreen>
    with SingleTickerProviderStateMixin {
  late TabController _tab;
  int _quizIndex = 0;
  int? _quizAnswer;
  bool _quizAnswered = false;
  int _quizCorrect = 0;

  @override
  void initState() {
    super.initState();
    _tab = TabController(length: 2, vsync: this);
  }

  @override
  void dispose() {
    _tab.dispose();
    super.dispose();
  }

  List<String> _quizOptions(int correctIdx) {
    final opts = [trafficSigns[correctIdx].name];
    final others = List<int>.generate(trafficSigns.length, (i) => i)
      ..remove(correctIdx);
    others.shuffle();
    opts.addAll(others.take(3).map((i) => trafficSigns[i].name));
    opts.shuffle();
    return opts;
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Trafik Levhaları'),
        bottom: TabBar(
          controller: _tab,
          tabs: const [
            Tab(text: 'Tüm Levhalar'),
            Tab(text: 'Levha Quiz'),
          ],
          labelColor: AppColors.primaryLight,
          unselectedLabelColor: AppColors.textSecondary,
          indicatorColor: AppColors.primaryLight,
        ),
      ),
      body: TabBarView(
        controller: _tab,
        children: [
          // ALL SIGNS
          GridView.builder(
            padding: const EdgeInsets.all(16),
            gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
              crossAxisCount: 2,
              childAspectRatio: 0.9,
              crossAxisSpacing: 12,
              mainAxisSpacing: 12,
            ),
            itemCount: trafficSigns.length,
            itemBuilder: (_, i) {
              final s = trafficSigns[i];
              return GestureDetector(
                onTap: () => _showSignDetail(context, s),
                child: Container(
                  decoration: BoxDecoration(
                    color: AppColors.surfaceCard,
                    borderRadius: BorderRadius.circular(18),
                  ),
                  padding: const EdgeInsets.all(16),
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Text(s.emoji, style: const TextStyle(fontSize: 48)),
                      const SizedBox(height: 8),
                      Text(
                        s.name,
                        style: const TextStyle(
                          color: AppColors.textPrimary,
                          fontWeight: FontWeight.w700,
                          fontSize: 15,
                        ),
                        textAlign: TextAlign.center,
                      ),
                      const SizedBox(height: 4),
                      Container(
                        padding: const EdgeInsets.symmetric(
                          horizontal: 8,
                          vertical: 2,
                        ),
                        decoration: BoxDecoration(
                          color: AppColors.primary.withOpacity(0.2),
                          borderRadius: BorderRadius.circular(8),
                        ),
                        child: Text(
                          s.type,
                          style: const TextStyle(
                            color: AppColors.primaryLight,
                            fontSize: 11,
                          ),
                        ),
                      ),
                    ],
                  ),
                ),
              );
            },
          ),
          // QUIZ
          _buildQuiz(),
        ],
      ),
    );
  }

  Widget _buildQuiz() {
    if (_quizIndex >= trafficSigns.length) {
      return Center(
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('🏆', style: TextStyle(fontSize: 64)),
            const SizedBox(height: 16),
            Text(
              'Quiz Tamamlandı!',
              style: const TextStyle(
                color: AppColors.textPrimary,
                fontWeight: FontWeight.w800,
                fontSize: 22,
              ),
            ),
            Text(
              '$_quizCorrect/${trafficSigns.length} doğru',
              style: const TextStyle(
                color: AppColors.primaryLight,
                fontSize: 16,
              ),
            ),
            const SizedBox(height: 24),
            ElevatedButton(
              onPressed: () => setState(() {
                _quizIndex = 0;
                _quizAnswer = null;
                _quizAnswered = false;
                _quizCorrect = 0;
              }),
              child: const Text('Tekrar Başla'),
            ),
          ],
        ),
      );
    }
    final sign = trafficSigns[_quizIndex];
    final opts = _quizOptions(_quizIndex % trafficSigns.length);
    final correctOpt = sign.name;
    return Padding(
      padding: const EdgeInsets.all(20),
      child: Column(
        children: [
          Text(
            'Soru ${_quizIndex + 1}/${trafficSigns.length}',
            style: const TextStyle(color: AppColors.textSecondary),
          ),
          const SizedBox(height: 8),
          ClipRRect(
            borderRadius: BorderRadius.circular(4),
            child: LinearProgressIndicator(
              value: _quizIndex / trafficSigns.length,
              minHeight: 5,
              backgroundColor: AppColors.surfaceLight,
              valueColor: const AlwaysStoppedAnimation<Color>(
                AppColors.primaryLight,
              ),
            ),
          ),
          const SizedBox(height: 32),
          const Text(
            'Bu levhanın adı nedir?',
            style: TextStyle(color: AppColors.textSecondary, fontSize: 15),
          ),
          const SizedBox(height: 16),
          Container(
            width: 120,
            height: 120,
            decoration: BoxDecoration(
              color: AppColors.surfaceCard,
              borderRadius: BorderRadius.circular(24),
            ),
            child: Center(
              child: Text(sign.emoji, style: const TextStyle(fontSize: 72)),
            ),
          ),
          const SizedBox(height: 32),
          ...opts.map((opt) {
            Color c = AppColors.surfaceLight;
            Color border = Colors.transparent;
            if (_quizAnswered) {
              if (opt == correctOpt) {
                c = AppColors.success.withOpacity(0.2);
                border = AppColors.success;
              } else if (_quizAnswer != null &&
                  opts[_quizAnswer!] == opt &&
                  opt != correctOpt) {
                c = AppColors.error.withOpacity(0.2);
                border = AppColors.error;
              }
            }
            return Padding(
              padding: const EdgeInsets.only(bottom: 10),
              child: GestureDetector(
                onTap: () {
                  if (_quizAnswered) return;
                  final idx = opts.indexOf(opt);
                  setState(() {
                    _quizAnswer = idx;
                    _quizAnswered = true;
                    if (opt == correctOpt) _quizCorrect++;
                  });
                },
                child: AnimatedContainer(
                  duration: const Duration(milliseconds: 250),
                  padding: const EdgeInsets.symmetric(
                    vertical: 14,
                    horizontal: 16,
                  ),
                  decoration: BoxDecoration(
                    color: c,
                    borderRadius: BorderRadius.circular(14),
                    border: Border.all(color: border, width: 2),
                  ),
                  child: Center(
                    child: Text(
                      opt,
                      style: const TextStyle(
                        color: AppColors.textPrimary,
                        fontWeight: FontWeight.w600,
                        fontSize: 15,
                      ),
                    ),
                  ),
                ),
              ),
            );
          }),
          if (_quizAnswered) ...[
            const SizedBox(height: 16),
            SizedBox(
              width: double.infinity,
              child: ElevatedButton(
                onPressed: () => setState(() {
                  _quizIndex++;
                  _quizAnswer = null;
                  _quizAnswered = false;
                }),
                child: Text(
                  _quizIndex < trafficSigns.length - 1
                      ? 'Sonraki →'
                      : 'Sonucu Gör',
                ),
              ),
            ),
          ],
        ],
      ),
    );
  }

  void _showSignDetail(BuildContext context, TrafficSign s) {
    showModalBottomSheet(
      context: context,
      backgroundColor: AppColors.surfaceCard,
      shape: const RoundedRectangleBorder(
        borderRadius: BorderRadius.vertical(top: Radius.circular(24)),
      ),
      builder: (_) => Padding(
        padding: const EdgeInsets.all(28),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text(s.emoji, style: const TextStyle(fontSize: 80)),
            const SizedBox(height: 12),
            Text(
              s.name,
              style: const TextStyle(
                color: AppColors.textPrimary,
                fontWeight: FontWeight.w800,
                fontSize: 22,
              ),
            ),
            const SizedBox(height: 4),
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 4),
              decoration: BoxDecoration(
                color: AppColors.primary.withOpacity(0.2),
                borderRadius: BorderRadius.circular(12),
              ),
              child: Text(
                s.type,
                style: const TextStyle(
                  color: AppColors.primaryLight,
                  fontWeight: FontWeight.w600,
                ),
              ),
            ),
            const SizedBox(height: 16),
            Text(
              s.description,
              style: const TextStyle(
                color: AppColors.textSecondary,
                fontSize: 15,
                height: 1.5,
              ),
              textAlign: TextAlign.center,
            ),
            const SizedBox(height: 24),
          ],
        ),
      ),
    );
  }
}

